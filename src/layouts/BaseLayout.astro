---
const { title = 'NeonLaunch', description = 'A modern landing page built with Astro.' } = Astro.props;
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <style>
      :root {
        --bg: #08111f;
        --panel: rgba(13, 23, 42, 0.75);
        --line: rgba(148, 163, 184, 0.18);
        --text: #e5eefc;
        --muted: #9fb0cc;
        --accent: #7c3aed;
        --accent-2: #06b6d4;
        --shadow: 0 20px 60px rgba(0, 0, 0, 0.35);
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        color: var(--text);
        background:
          radial-gradient(circle at top left, rgba(124, 58, 237, 0.25), transparent 30%),
          radial-gradient(circle at top right, rgba(6, 182, 212, 0.2), transparent 24%),
          linear-gradient(180deg, #020617, #08111f 40%, #020617);
        min-height: 100vh;
      }
      a { color: inherit; text-decoration: none; }
      .container { width: min(1120px, calc(100% - 32px)); margin: 0 auto; }
      .nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 20px 0;
      }
      .logo {
        font-weight: 800;
        letter-spacing: 0.05em;
      }
      .nav-links {
        display: flex;
        gap: 18px;
        color: var(--muted);
        font-size: 14px;
      }
      .hero {
        display: grid;
        grid-template-columns: 1.2fr 0.8fr;
        gap: 32px;
        align-items: center;
        padding: 56px 0 40px;
      }
      .hero-card,
      .panel {
        background: var(--panel);
        backdrop-filter: blur(14px);
        border: 1px solid var(--line);
        border-radius: 28px;
        box-shadow: var(--shadow);
      }
      .hero-card { padding: 42px; }
      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 14px;
        border-radius: 999px;
        font-size: 13px;
        color: #c7d2fe;
        background: rgba(124, 58, 237, 0.12);
        border: 1px solid rgba(124, 58, 237, 0.28);
      }
      h1 {
        margin: 18px 0 16px;
        font-size: clamp(40px, 7vw, 74px);
        line-height: 0.96;
        letter-spacing: -0.04em;
      }
      .lead {
        margin: 0 0 26px;
        color: var(--muted);
        font-size: 18px;
        line-height: 1.7;
        max-width: 60ch;
      }
      .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
      }
      .button {
        padding: 14px 20px;
        border-radius: 14px;
        font-weight: 700;
        transition: transform 0.2s ease;
      }
      .button:hover { transform: translateY(-1px); }
      .button.primary {
        background: linear-gradient(135deg, var(--accent), var(--accent-2));
      }
      .button.secondary {
        border: 1px solid var(--line);
        color: var(--muted);
      }
      .stats {
        margin-top: 28px;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
      }
      .stat {
        padding: 16px;
        border-radius: 20px;
        background: rgba(15, 23, 42, 0.6);
        border: 1px solid var(--line);
      }
      .stat strong {
        display: block;
        font-size: 24px;
        margin-bottom: 6px;
      }
      .dashboard {
        padding: 24px;
        display: grid;
        gap: 16px;
      }
      .dashboard-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        color: var(--muted);
        font-size: 14px;
      }
      .chart {
        height: 220px;
        border-radius: 22px;
        background:
          linear-gradient(180deg, rgba(124, 58, 237, 0.18), rgba(124, 58, 237, 0.03)),
          linear-gradient(90deg, rgba(148, 163, 184, 0.06) 1px, transparent 1px),
          linear-gradient(180deg, rgba(148, 163, 184, 0.06) 1px, transparent 1px);
        background-size: auto, 40px 40px, 40px 40px;
        position: relative;
        overflow: hidden;
      }
      .chart::after {
        content: '';
        position: absolute;
        inset: auto 10% 18% 8%;
        height: 3px;
        border-radius: 999px;
        background: linear-gradient(90deg, #22c55e, #06b6d4, #7c3aed, #f59e0b);
        transform: skewY(-12deg);
        box-shadow: 0 -26px 0 0 rgba(6, 182, 212, 0.65), 120px -70px 0 0 rgba(124, 58, 237, 0.8), 240px -20px 0 0 rgba(34, 197, 94, 0.85), 360px -90px 0 0 rgba(245, 158, 11, 0.85);
      }
      .feature-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 18px;
        padding: 12px 0 72px;
      }
      .panel { padding: 24px; }
      .panel h3 { margin: 0 0 10px; font-size: 20px; }
      .panel p { margin: 0; color: var(--muted); line-height: 1.7; }
      footer {
        padding: 0 0 40px;
        color: var(--muted);
        text-align: center;
      }
      @media (max-width: 900px) {
        .hero,
        .feature-grid {
          grid-template-columns: 1fr;
        }
      }
      @media (max-width: 640px) {
        .nav { flex-direction: column; gap: 14px; }
        .nav-links { flex-wrap: wrap; justify-content: center; }
        .hero-card { padding: 28px; }
        .stats { grid-template-columns: 1fr; }
        .dashboard { padding: 18px; }
      }
    </style>
  </head>
  <body>
    <div class="container">
      <nav class="nav">
        <a href="#" class="logo">NEONLAUNCH</a>
        <div class="nav-links">
          <a href="#features">Features</a>
          <a href="#showcase">Showcase</a>
          <a href="#contact">Contact</a>
        </div>
      </nav>
      <slot />
      <footer id="contact">© 2026 NeonLaunch. Built for fast free deployment.</footer>
    </div>
  </body>
</html>
